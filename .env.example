# Provide at least one provider key. Each stage skips providers whose key is missing,
# so the engine still runs (with reduced breadth) on a single key.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Optional: enables `--research` (Tavily web search augmentation).
TAVILY_API_KEY=

# Observability (optional) — one instrumentation, route to any/all backends.
# Langfuse (self-host or cloud):
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LangSmith:
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=llm-debate-swarm
# Generic OTLP collector (Jaeger / Tempo / your own):
OTEL_EXPORTER_OTLP_ENDPOINT=
